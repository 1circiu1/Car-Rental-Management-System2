<Page
    x:Class="Project.Views.Dashboard.Admin.AdminSupportTicketsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="24">

            <StackPanel Spacing="6">
                <TextBlock Text="Support Tickets"
                           FontSize="32"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Review customer support requests and update ticket status."
                           FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="22"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Pending tickets"/>
                        <TextBlock x:Name="OpenTicketsText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="22"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="In progress"/>
                        <TextBlock x:Name="InProgressTicketsText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="22"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Resolved"/>
                        <TextBlock x:Name="ResolvedTicketsText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="24"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="18">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Tickets list"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>

                        <ComboBox x:Name="TicketFilterBox"
                                  Grid.Column="1"
                                  Width="170"
                                  SelectedIndex="0"
                                  SelectionChanged="TicketFilterBox_SelectionChanged">
                            <ComboBoxItem Content="All"/>
                            <ComboBoxItem Content="Pending"/>
                            <ComboBoxItem Content="In Progress"/>
                            <ComboBoxItem Content="Resolved"/>
                        </ComboBox>
                    </Grid>

                    <StackPanel x:Name="TicketsPanel"
                                Spacing="14"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>