<Page
    x:Class="Project.Views.Dashboard.Admin.AdminReturnedReservationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="24">

            <StackPanel Spacing="6">
                <TextBlock Text="Returned Reservations"
                           FontSize="32"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Confirm returned vehicles and complete rentals after DriveEase garage inspection."
                           FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="22"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Waiting confirmation"/>
                        <TextBlock x:Name="ReturnedCountText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="22"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Late fees pending"/>
                        <TextBlock x:Name="LateFeesText"
                                   Text="€ 0.00"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="22"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Pending final value"/>
                        <TextBlock x:Name="PendingFinalValueText"
                                   Text="€ 0.00"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="24"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="18">

                    <TextBlock Text="Returned vehicles"
                               FontSize="22"
                               FontWeight="SemiBold"/>

                    <StackPanel x:Name="ReturnedReservationsPanel"
                                Spacing="14"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>