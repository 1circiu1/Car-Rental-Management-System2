<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Project.Views.Dashboard.Admin.AdminOverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Project.Views.Dashboard.Admin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="40">
            <StackPanel Spacing="28">

                <StackPanel Spacing="6">
                    <TextBlock Text="Admin Overview"
                           FontSize="32"
                           FontWeight="SemiBold"/>

                    <TextBlock Text="Monitor DriveEase platform activity and business performance."
                           FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0"
                        Padding="24"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Customers" FontSize="16"/>
                            <TextBlock x:Name="CustomersCountText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                            <TextBlock Text="Registered customers"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1"
                        Padding="24"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Car renters" FontSize="16"/>
                            <TextBlock x:Name="CarRentersCountText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                            <TextBlock Text="Vehicle owners"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="2"
                        Padding="24"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Cars" FontSize="16"/>
                            <TextBlock x:Name="CarsCountText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                            <TextBlock Text="Vehicles on platform"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0"
                        Padding="24"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Returned reservations" FontSize="16"/>
                            <TextBlock x:Name="ReturnedReservationsCountText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                            <TextBlock Text="Waiting for admin confirmation"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1"
                        Padding="24"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Completed rentals" FontSize="16"/>
                            <TextBlock x:Name="CompletedRentalsCountText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                            <TextBlock Text="Finalized rentals"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="2"
                        Padding="24"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Company revenue this month" FontSize="16"/>
                            <TextBlock x:Name="MonthlyRevenueText"
                                   Text="€ 0.00"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                            <TextBlock Text="15% DriveEase fee from completed rentals"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Padding="24"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Next admin sections"
                               FontSize="22"
                               FontWeight="SemiBold"/>

                        <TextBlock Text="Returned Reservations - confirm returned vehicles and complete rentals."/>
                        <TextBlock Text="Company Revenue - track total revenue and monthly earnings."/>
                        <TextBlock Text="Support Tickets - manage customer support requests."/>
                        <TextBlock Text="Garages - monitor DriveEase garage activity."/>
                    </StackPanel>
                </Border>

                <Button Content="Sign out"
                    Width="140"
                    Click="SignOut_Click"/>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
