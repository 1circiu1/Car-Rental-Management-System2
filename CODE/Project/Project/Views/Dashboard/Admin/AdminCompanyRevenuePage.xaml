<Page
    x:Class="Project.Views.Dashboard.Admin.AdminCompanyRevenuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Spacing="24">

            <StackPanel Spacing="6">
                <TextBlock Text="Company Revenue"
                           FontSize="32"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Track DriveEase commission from completed rentals."
                           FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="22"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Total company revenue"/>
                        <TextBlock x:Name="TotalCompanyRevenueText"
                                   Text="€ 0.00"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="22"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="This month"/>
                        <TextBlock x:Name="MonthlyCompanyRevenueText"
                                   Text="€ 0.00"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="22"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Completed rentals"/>
                        <TextBlock x:Name="CompletedRentalsText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="24"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="18">
                    <TextBlock Text="Completed rental transactions"
                               FontSize="22"
                               FontWeight="SemiBold"/>

                    <StackPanel x:Name="TransactionsPanel"
                                Spacing="14"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>