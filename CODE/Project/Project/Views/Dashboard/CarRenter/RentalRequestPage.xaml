<Page
    x:Class="Project.Views.Dashboard.CarRenter.RentalRequestsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <StackPanel>
                <TextBlock Text="Rental Requests"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Review and manage customer rental requests."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Pending Requests" FontSize="14"/>
                        <TextBlock Text="0" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Approved" FontSize="14"/>
                        <TextBlock Text="0" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Rejected" FontSize="14"/>
                        <TextBlock Text="0" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Requests List"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <ComboBox Grid.Column="1"
                                  SelectedIndex="0"
                                  Width="160">
                            <ComboBoxItem Content="All requests"/>
                            <ComboBoxItem Content="Pending"/>
                            <ComboBoxItem Content="Approved"/>
                            <ComboBoxItem Content="Rejected"/>
                        </ComboBox>
                    </Grid>

                    <Border Padding="40"
                            CornerRadius="10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">

                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="12">

                            <FontIcon Glyph="&#xE787;"
                                      FontSize="40"
                                      HorizontalAlignment="Center"/>

                            <TextBlock Text="No rental requests yet"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="When customers request your cars, they will appear here."
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>