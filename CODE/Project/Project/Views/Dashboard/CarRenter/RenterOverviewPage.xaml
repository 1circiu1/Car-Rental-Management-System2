<Page
    x:Class="Project.Views.Dashboard.CarRenter.RenterOverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <StackPanel>
                <TextBlock Text="Owner Overview"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Quick summary of your fleet, rental requests and earnings."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Stats -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Listed Cars" FontSize="14"/>
                        <TextBlock x:Name="ListedCarsText" Text="0" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Available" FontSize="14"/>
                        <TextBlock x:Name="AvailableCarsText" Text="0" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="In Maintenance" FontSize="14"/>
                        <TextBlock x:Name="MaintenanceCarsText" Text="0" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Potential / Month" FontSize="14"/>
                        <TextBlock x:Name="PotentialMonthText" Text="$0" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Content -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Activity -->
                <Border Grid.Column="0"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="16">
                        <TextBlock Text="Fleet Summary"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <StackPanel x:Name="FleetSummaryPanel"
                                    Spacing="12"/>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <Border Grid.Column="1"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="14">
                        <TextBlock Text="Quick Actions"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Button HorizontalAlignment="Stretch"
                                Content="+ List a new car"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="GoToMyFleet_Click"/>

                        <Button HorizontalAlignment="Stretch"
                                Content="View booking requests"
                                Click="GoToBookingRequests_Click"/>

                        <Button HorizontalAlignment="Stretch"
                                Content="Check vehicle monitoring"
                                Click="GoToVehicleMonitoring_Click"/>

                        <Button HorizontalAlignment="Stretch"
                                Content="Open earnings report"
                                Click="GoToRevenue_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Summary -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Fleet Health"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock x:Name="FleetHealthText"
                                   Text="No fleet data available yet."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <Border Padding="12"
                                CornerRadius="10"
                                Background="#2234C759">
                            <TextBlock x:Name="FleetHealthBadgeText"
                                       Text="Fleet status will appear here."
                                       Foreground="#FF34C759"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Next Recommended Step"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock x:Name="NextStepText"
                                   Text="Start by listing your first car."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <Button x:Name="NextStepButton"
                                Content="Go to My Fleet"
                                HorizontalAlignment="Left"
                                Click="GoToMyFleet_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>