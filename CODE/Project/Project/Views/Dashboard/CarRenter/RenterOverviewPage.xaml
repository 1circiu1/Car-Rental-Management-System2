<Page
    x:Class="Project.Views.Dashboard.CarRenter.RenterOverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <!-- Header -->
            <StackPanel>
                <TextBlock Text="Owner Overview"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Quick summary of your fleet, rental requests and earnings."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Stats -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Listed Cars" FontSize="14"/>
                        <TextBlock Text="3" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Available" FontSize="14"/>
                        <TextBlock Text="2" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Pending Requests" FontSize="14"/>
                        <TextBlock Text="4" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="This Month" FontSize="14"/>
                        <TextBlock Text="$245" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Content -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Activity -->
                <Border Grid.Column="0"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="16">
                        <TextBlock Text="Recent Activity"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Border Padding="14"
                                CornerRadius="10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        Background="#2234C759">
                                    <FontIcon Glyph="&#xE73E;"
                                              FontSize="16"
                                              Foreground="#FF34C759"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="BMW 3 Series returned successfully"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Vehicle marked as clean and ready for next rental."
                                               FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="Today"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </Border>

                        <Border Padding="14"
                                CornerRadius="10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        Background="#221A6EF5">
                                    <FontIcon Glyph="&#xE787;"
                                              FontSize="16"
                                              Foreground="#FF6EA8FE"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="New rental request received"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Tesla Model 3 requested for 3 days."
                                               FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="2h ago"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </Border>

                        <Border Padding="14"
                                CornerRadius="10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        Background="#22FF9500">
                                    <FontIcon Glyph="&#xE8C7;"
                                              FontSize="16"
                                              Foreground="#FFFF9500"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Payment completed"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="$90 added from a completed rental."
                                               FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="Yesterday"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <Border Grid.Column="1"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="14">
                        <TextBlock Text="Quick Actions"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Button HorizontalAlignment="Stretch"
                            Content="+ List a new car"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="GoToMyFleet_Click"/>

                        <Button HorizontalAlignment="Stretch"
                            Content="View booking requests"
                            Click="GoToBookingRequests_Click"/>

                        <Button HorizontalAlignment="Stretch"
                            Content="Check vehicle monitoring"
                            Click="GoToVehicleMonitoring_Click"/>

                        <Button HorizontalAlignment="Stretch"
                            Content="Open earnings report"
                            Click="GoToRevenue_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Summary -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Fleet Health"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="2 vehicles are ready for rent. 1 vehicle is currently rented."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <Border Padding="12"
                                CornerRadius="10"
                                Background="#2234C759">
                            <TextBlock Text="All listed vehicles are in good condition."
                                       Foreground="#FF34C759"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Next Recommended Step"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Review pending booking requests and update vehicle availability if needed."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <Button Content="Review requests"
                                HorizontalAlignment="Left"
                                Click="GoToBookingRequests_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>