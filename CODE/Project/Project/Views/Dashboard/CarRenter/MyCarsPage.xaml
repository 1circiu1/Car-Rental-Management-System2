<Page
    x:Class="Project.Views.Dashboard.CarRenter.MyCarsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <!-- Header -->
            <StackPanel>
                <TextBlock Text="My Cars"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Manage your listed cars, pricing and availability."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Stats -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Total Cars" FontSize="14"/>
                        <TextBlock Text="3"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Available" FontSize="14"/>
                        <TextBlock Text="2"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Currently Rented" FontSize="14"/>
                        <TextBlock Text="1"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Cars Section -->
            <Border Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Listed Cars"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Button Grid.Column="1"
                                Content="+ Add Car"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="AddCar_Click"/>
                    </Grid>

                    <!-- Car 1 -->
                    <Border Padding="16"
                            CornerRadius="10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="72"
                                    Height="72"
                                    CornerRadius="10"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">

                                <FontIcon Glyph="&#xE804;"
                                          FontSize="28"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Spacing="6">

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">

                                    <TextBlock Text="BMW 3 Series"
                                               FontSize="17"
                                               FontWeight="SemiBold"/>

                                    <Border Padding="8,3"
                                            CornerRadius="10"
                                            Background="#2234C759">

                                        <TextBlock Text="Available"
                                                   FontSize="11"
                                                   Foreground="#FF34C759"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="2021 • Automatic • Cluj-Napoca"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Text="$65 / day"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">

                                <Button Content="Edit"/>
                                <Button Content="Maintenance"/>
                                <Button Content="Remove"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Car 2 -->
                    <Border Padding="16"
                            CornerRadius="10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="72"
                                    Height="72"
                                    CornerRadius="10"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">

                                <FontIcon Glyph="&#xE804;"
                                          FontSize="28"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Spacing="6">

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">

                                    <TextBlock Text="Tesla Model 3"
                                               FontSize="17"
                                               FontWeight="SemiBold"/>

                                    <Border Padding="8,3"
                                            CornerRadius="10"
                                            Background="#22FF9500">

                                        <TextBlock Text="Rented"
                                                   FontSize="11"
                                                   Foreground="#FFFF9500"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="2022 • Electric • Bucuresti"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Text="$90 / day"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">

                                <Button Content="Edit"/>
                                <Button Content="Details"/>
                                <Button Content="Remove"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Car 3 -->
                    <Border Padding="16"
                            CornerRadius="10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="72"
                                    Height="72"
                                    CornerRadius="10"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">

                                <FontIcon Glyph="&#xE804;"
                                          FontSize="28"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Spacing="6">

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">

                                    <TextBlock Text="Audi A4"
                                               FontSize="17"
                                               FontWeight="SemiBold"/>

                                    <Border Padding="8,3"
                                            CornerRadius="10"
                                            Background="#2234C759">

                                        <TextBlock Text="Available"
                                                   FontSize="11"
                                                   Foreground="#FF34C759"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="2020 • Manual • Brasov"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Text="$55 / day"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">

                                <Button Content="Edit"/>
                                <Button Content="Maintenance"/>
                                <Button Content="Remove"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>