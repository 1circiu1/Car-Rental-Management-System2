<Page
    x:Class="Project.Views.Dashboard.CarRenter.RentalRequestsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <StackPanel>
                <TextBlock Text="Rental Requests"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Review and manage customer rental requests."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                
                <TextBlock Text="🟡 Pending → 🔵 Confirmed → 🟣 PickedUp → 🔷 Returned → ⚪ Completed"
                           FontSize="14"
                           Margin="0,10,0,0"/>
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Pending Requests" FontSize="14"/>
                        <TextBlock x:Name="PendingRequestsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Approved" FontSize="14"/>
                        <TextBlock x:Name="ApprovedRequestsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="20" CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Rejected" FontSize="14"/>
                        <TextBlock x:Name="RejectedRequestsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Requests List"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <ComboBox x:Name="RequestsFilterBox"
                                  Grid.Column="1"
                                  SelectedIndex="0"
                                  Width="160"
                                  SelectionChanged="RequestsFilterBox_SelectionChanged">
                            <ComboBoxItem Content="All requests"/>
                            <ComboBoxItem Content="Pending"/>
                            <ComboBoxItem Content="Confirmed"/>
                            <ComboBoxItem Content="PickedUp"/>
                            <ComboBoxItem Content="Returned"/>
                            <ComboBoxItem Content="Completed"/>
                            <ComboBoxItem Content="Cancelled"/>
                        </ComboBox>
                    </Grid>

                    <StackPanel x:Name="RequestsListPanel"
                                Spacing="12"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>