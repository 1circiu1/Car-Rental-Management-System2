<Page
    x:Class="Project.Views.Dashboard.CarRenter.EarningsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <!-- Header -->
            <StackPanel>
                <TextBlock Text="Earnings"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Track your rental income and statistics."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Stats -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Total Earnings"
                                   FontSize="14"/>
                        <TextBlock Text="$0"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="This Month"
                                   FontSize="14"/>
                        <TextBlock Text="$0"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Completed Rentals"
                                   FontSize="14"/>
                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Earnings Section -->
            <Border Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="16">

                    <TextBlock Text="Income Overview"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Border Padding="40"
                            CornerRadius="10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">

                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="12">

                            <FontIcon Glyph="&#xEAFD;"
                                      FontSize="40"
                                      HorizontalAlignment="Center"/>

                            <TextBlock Text="No earnings data yet"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Your rental earnings and analytics will appear here."
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>