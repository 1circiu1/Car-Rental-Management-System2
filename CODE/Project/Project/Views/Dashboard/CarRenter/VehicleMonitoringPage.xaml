<Page
    x:Class="Project.Views.Dashboard.CarRenter.VehicleMonitoringPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <StackPanel>
                <TextBlock Text="Vehicle Monitoring"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Track live status, maintenance needs and renter feedback."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Stats -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Needs Inspection" FontSize="14"/>
                        <TextBlock x:Name="NeedsInspectionText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="In Maintenance" FontSize="14"/>
                        <TextBlock x:Name="InMaintenanceText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="20"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Reports This Month" FontSize="14"/>
                        <TextBlock x:Name="ReportsThisMonthText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Live Vehicle Status -->
            <Border Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Live Vehicle Status"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <ComboBox x:Name="StatusFilterBox"
                                  Grid.Column="1"
                                  SelectedIndex="0"
                                  Width="170"
                                  SelectionChanged="StatusFilterBox_SelectionChanged">
                            <ComboBoxItem Content="All vehicles"/>
                            <ComboBoxItem Content="Available"/>
                            <ComboBoxItem Content="Rented"/>
                            <ComboBoxItem Content="Maintenance"/>
                        </ComboBox>
                    </Grid>

                    <StackPanel x:Name="VehicleStatusPanel"
                                Spacing="12"/>

                </StackPanel>
            </Border>

            <!-- Monitoring Categories -->
            <Border Padding="20"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="16">
                    <TextBlock Text="Monitoring Categories"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="16"
                                CornerRadius="10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Live Status" FontWeight="SemiBold"/>
                                <TextBlock Text="Track available, rented, late return or inactive vehicles."
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Padding="16"
                                CornerRadius="10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Maintenance" FontWeight="SemiBold"/>
                                <TextBlock Text="Track damage, repairs, inspection notes and required checks."
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="16"
                                CornerRadius="10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Renter Feedback" FontWeight="SemiBold"/>
                                <TextBlock Text="Review how the renter returned the vehicle after each booking."
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>