<Page
    x:Class="Project.Views.Dashboard.Customer.SupportTicketDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer>
        <Grid Padding="40">
            <Border MaxWidth="900"
                    HorizontalAlignment="Center"
                    Padding="32"
                    CornerRadius="24"
                    Background="#26263A"
                    BorderBrush="#3B3B5C"
                    BorderThickness="1">

                <StackPanel Spacing="18">

                    <Button Content="← Back"
                            Width="110"
                            Click="Back_Click"/>

                    <TextBlock Text="Support Ticket Details"
                               Foreground="White"
                               FontSize="34"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="SubjectText"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="CategoryText"
                               Foreground="#A78BFA"
                               FontSize="15"/>

                    <TextBlock x:Name="StatusText"
                               Foreground="#FBBF24"
                               FontSize="15"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="CreatedAtText"
                               Foreground="#9CA3AF"
                               FontSize="13"/>

                    <Border Padding="18"
                            CornerRadius="16"
                            Background="#111827"
                            BorderBrush="#334155"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Your message"
                                       Foreground="#A78BFA"
                                       FontSize="15"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="MessageText"
                                       Foreground="White"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Padding="18"
                            CornerRadius="16"
                            Background="#111827"
                            BorderBrush="#334155"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Admin response"
                                       Foreground="#60A5FA"
                                       FontSize="15"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="AdminResponseText"
                                       Foreground="White"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="ResolvedAtText"
                                       Foreground="#9CA3AF"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>