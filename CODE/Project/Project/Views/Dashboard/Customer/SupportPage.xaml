<Page
    x:Class="Project.Views.Dashboard.SupportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="22">

            <!-- Header -->
            <StackPanel Spacing="6">
                <TextBlock Text="Help &amp; Support"
                           FontSize="32"
                           FontWeight="SemiBold"
                           Foreground="White"/>

                <TextBlock Text="Get help with your reservations, payments, vehicle issues, or account."
                           FontSize="14"
                           Foreground="#D1D5DB"/>
            </StackPanel>

            <!-- Top cards -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="20"
                        CornerRadius="18"
                        Background="#26263A"
                        BorderBrush="#3B3B5C"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE8BD;" Foreground="#A78BFA" FontSize="24"/>
                        <TextBlock Text="Active tickets" Foreground="#D1D5DB"/>
                        <TextBlock x:Name="ActiveTicketsText"
                                   Text="0"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="20"
                        CornerRadius="18"
                        Background="#26263A"
                        BorderBrush="#3B3B5C"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE916;" Foreground="#60A5FA" FontSize="24"/>
                        <TextBlock Text="Avg. response" Foreground="#D1D5DB"/>
                        <TextBlock Text="12 min"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="20"
                        CornerRadius="18"
                        Background="#26263A"
                        BorderBrush="#3B3B5C"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE930;" Foreground="#34D399" FontSize="24"/>
                        <TextBlock Text="Support status" Foreground="#D1D5DB"/>
                        <TextBlock Text="Online"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Padding="20"
                        CornerRadius="18"
                        Background="#26263A"
                        BorderBrush="#3B3B5C"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE717;" Foreground="#F87171" FontSize="24"/>
                        <TextBlock Text="Emergency line" Foreground="#D1D5DB"/>
                        <TextBlock Text="24/7"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick categories -->
            <Border Padding="22"
                    CornerRadius="22"
                    Background="#26263A"
                    BorderBrush="#3B3B5C"
                    BorderThickness="1">

                <StackPanel Spacing="16">
                    <TextBlock Text="Quick help categories"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>

                    <Grid ColumnSpacing="14" RowSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Grid.Column="0"
                                x:Name="BtnReservation"
                                Tag="Reservation"
                                Click="CategoryButton_Click"
                                Background="#1E293B"
                                BorderBrush="#3B3B5C"
                                BorderThickness="1"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <FontIcon Glyph="&#xE787;" Foreground="#A78BFA" FontSize="22"/>
                                <TextBlock Text="Reservation issue" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="0" Grid.Column="1"
                                x:Name="BtnPayment"
                                Tag="Payment"
                                Click="CategoryButton_Click"
                                Background="#1E293B"
                                BorderBrush="#3B3B5C"
                                BorderThickness="1"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <FontIcon Glyph="&#xE8C7;" Foreground="#60A5FA" FontSize="22"/>
                                <TextBlock Text="Payment issue" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="0" Grid.Column="2"
                                x:Name="BtnVehicle"
                                Tag="Vehicle"
                                Click="CategoryButton_Click"
                                Background="#1E293B"
                                BorderBrush="#3B3B5C"
                                BorderThickness="1"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <FontIcon Glyph="&#xE804;" Foreground="#FBBF24" FontSize="22"/>
                                <TextBlock Text="Vehicle damage" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="1" Grid.Column="0"
                                x:Name="BtnLateReturn"
                                Tag="Late return"
                                Click="CategoryButton_Click"
                                Background="#1E293B"
                                BorderBrush="#3B3B5C"
                                BorderThickness="1"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <FontIcon Glyph="&#xE916;" Foreground="#F87171" FontSize="22"/>
                                <TextBlock Text="Late return" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="1" Grid.Column="1"
                                x:Name="BtnAccount"
                                Tag="Account"
                                Click="CategoryButton_Click"
                                Background="#1E293B"
                                BorderBrush="#3B3B5C"
                                BorderThickness="1"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <FontIcon Glyph="&#xE77B;" Foreground="#93C5FD" FontSize="22"/>
                                <TextBlock Text="Account issue" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="1" Grid.Column="2"
                                x:Name="BtnOther"
                                Tag="Other"
                                Click="CategoryButton_Click"
                                Background="#1E293B"
                                BorderBrush="#3B3B5C"
                                BorderThickness="1"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <FontIcon Glyph="&#xE897;" Foreground="#C4B5FD" FontSize="22"/>
                                <TextBlock Text="Other" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <StackPanel Grid.Column="0" Spacing="22">

                    <!-- Emergency -->
                    <Border Padding="24"
                            CornerRadius="22"
                            BorderBrush="#FCA5A5"
                            BorderThickness="1">

                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#DC2626" Offset="0"/>
                                <GradientStop Color="#991B1B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE717;"
                                          FontSize="24"
                                          Foreground="White"/>

                                <TextBlock Text="Emergency roadside assistance"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>

                            <TextBlock Text="Call +40 741 222 111"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="Available 24/7 for accidents, vehicle breakdowns, and urgent roadside problems."
                                       Foreground="#FEE2E2"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Required information -->
                    <Border Padding="24"
                            CornerRadius="22"
                            Background="#1E293B"
                            BorderBrush="#3B3B5C"
                            BorderThickness="1">

                        <StackPanel Spacing="14">

                            <TextBlock Text="Required information before submitting a ticket"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Faster support checklist"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#A78BFA"/>

                            <StackPanel Spacing="8">

                                <TextBlock Text="• Reservation ID"
                           Foreground="#D1D5DB"/>

                                <TextBlock Text="• Vehicle model"
                           Foreground="#D1D5DB"/>

                                <TextBlock Text="• Pick-up city"
                           Foreground="#D1D5DB"/>

                                <TextBlock Text="• Screenshots / photos"
                           Foreground="#D1D5DB"/>

                                <TextBlock Text="• Payment proof (if applicable)"
                           Foreground="#D1D5DB"/>

                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- RIGHT SIDE -->
                <StackPanel Grid.Column="1" Spacing="22">


                    <!-- FAQ -->
                    <Border Padding="24"
                            CornerRadius="22"
                            Background="#26263A"
                            BorderBrush="#3B3B5C"
                            BorderThickness="1">

                        <StackPanel Spacing="12">
                            <TextBlock Text="Frequently asked questions"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"/>

                            <Expander Header="How do I cancel a reservation?">
                                <TextBlock Text="Go to Reservations, select your booking, then choose Cancel reservation."
                               TextWrapping="Wrap"
                               Foreground="#D1D5DB"/>
                            </Expander>

                            <Expander Header="What happens if I return late?">
                                <TextBlock Text="Late returns may affect the next booking. Please contact support if you cannot return on time."
                               TextWrapping="Wrap"
                               Foreground="#D1D5DB"/>
                            </Expander>

                            <Expander Header="What should I do if the car is damaged?">
                                <TextBlock Text="Take photos immediately, avoid driving if the vehicle is unsafe, and open a support ticket under Vehicle damage."
                               TextWrapping="Wrap"
                               Foreground="#D1D5DB"/>
                            </Expander>

                            <Expander Header="Can I extend my booking?">
                                <TextBlock Text="You can request an extension through support, depending on vehicle availability."
                               TextWrapping="Wrap"
                               Foreground="#D1D5DB"/>
                            </Expander>

                            <Expander Header="How do refunds work?">
                                <TextBlock Text="Refunds depend on the reservation status and cancellation time."
                               TextWrapping="Wrap"
                               Foreground="#D1D5DB"/>
                            </Expander>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

            <!-- Recent tickets -->
            <Border Padding="24"
                    CornerRadius="22"
                    Background="#26263A"
                    BorderBrush="#3B3B5C"
                    BorderThickness="1">

                <StackPanel Spacing="14">
                    <TextBlock Text="Recent support requests"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <ListView x:Name="RecentTicketsList"
                              SelectionMode="None"
                              Background="Transparent">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="16"
                                        CornerRadius="16"
                                        Background="#1E293B"
                                        BorderBrush="#334155"
                                        BorderThickness="1">

                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="{Binding Subject}"
                                                       Foreground="White"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>

                                            <TextBlock Text="{Binding Category}"
                                                       Foreground="#A78BFA"
                                                       FontSize="13"/>

                                            <TextBlock Text="{Binding Message}"
                                                       Foreground="#9CA3AF"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    Spacing="6">

                                            <Border Background="#F59E0B"
                                                    CornerRadius="10"
                                                    Padding="10,4">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="White"
                                                           FontSize="12"/>
                                            </Border>

                                            <TextBlock Text="{Binding CreatedAt}"
                                                       Foreground="#9CA3AF"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>