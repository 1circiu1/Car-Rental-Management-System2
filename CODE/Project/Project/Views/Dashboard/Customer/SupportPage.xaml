<Page
    x:Class="Project.Views.Dashboard.SupportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel Spacing="16">
            <TextBlock Text="Help &amp; Support"
                       FontSize="28"
                       FontWeight="SemiBold"/>

            <TextBlock Text="Get help with your reservations, payments, or account."
                       FontSize="14"
                       Opacity="0.7"/>

            <Border Padding="20"
                    CornerRadius="12"
                    Background="#252525">
                <StackPanel Spacing="12">

                    <TextBlock Text="Contact support"
               FontSize="18"
               FontWeight="SemiBold"/>

                    <TextBox x:Name="SubjectTextBox"
             Header="Subject"
             PlaceholderText="Example: Problem with my reservation"/>

                    <ComboBox x:Name="CategoryComboBox"
              Header="Category"
              PlaceholderText="Select a category">

                        <ComboBoxItem Content="Reservation"/>
                        <ComboBoxItem Content="Payment"/>
                        <ComboBoxItem Content="Account"/>
                        <ComboBoxItem Content="Other"/>

                    </ComboBox>

                    <TextBox x:Name="MessageTextBox"
             Header="Message"
             PlaceholderText="Describe your problem..."
             AcceptsReturn="True"
             Height="120"/>

                    <Button Content="Submit ticket"
            HorizontalAlignment="Left"
            Click="SubmitTicket_Click"/>

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>