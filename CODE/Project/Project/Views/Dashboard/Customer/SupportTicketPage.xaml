<Page
    x:Class="Project.Views.Dashboard.Customer.SupportTicketPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="40">

            <Border MaxWidth="980"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Padding="34"
                    CornerRadius="24"
                    Background="#26263A"
                    BorderBrush="#3B3B5C"
                    BorderThickness="1">

                <StackPanel Spacing="18">

                    <Button Content="← Back"
                            Width="110"
                            Click="Back_Click"/>

                    <TextBlock Text="Contact support"
                               Foreground="White"
                               FontSize="34"
                               FontWeight="SemiBold"/>

                    <Border Padding="16"
                            CornerRadius="14"
                            Background="#1E293B"
                            BorderBrush="#334155"
                            BorderThickness="1">

                        <StackPanel Spacing="4">
                            <TextBlock Text="Selected category"
                                       Foreground="#94A3B8"
                                       FontSize="13"/>

                            <TextBlock x:Name="CategoryText"
                                       Text="Other"
                                       Foreground="#A78BFA"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <TextBox x:Name="SubjectTextBox"
                             Header="Subject"
                             PlaceholderText="Example: Problem with my reservation"/>

                    <TextBox x:Name="MessageTextBox"
                             Header="Message"
                             PlaceholderText="Describe your problem..."
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="220"/>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Attach image or screenshot"
                                Click="AttachButton_Click"/>

                        <TextBlock Grid.Column="1"
                                   x:Name="AttachedFileText"
                                   Text="No file attached"
                                   Foreground="#9CA3AF"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock x:Name="StatusText"
                               Text=""
                               Foreground="#34D399"
                               FontSize="13"
                               TextWrapping="Wrap"/>

                    <Button Content="Submit ticket"
                            Height="48"
                            HorizontalAlignment="Stretch"
                            Background="#8B5CF6"
                            Foreground="White"
                            Click="SubmitTicket_Click"/>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>