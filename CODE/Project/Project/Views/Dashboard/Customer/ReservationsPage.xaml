<Page
    x:Class="Project.Views.Dashboard.ReservationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="28">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#181825" Offset="0"/>
                <GradientStop Color="#221B2E" Offset="0.45"/>
                <GradientStop Color="#10243F" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer>
            <StackPanel Spacing="18">
                <TextBlock Text="Your reservations"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="SemiBold"/>

                <ListView x:Name="ReservationsList"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,16"
                                    Padding="20"
                                    CornerRadius="22"
                                    Background="#26263A"
                                    BorderBrush="#3B3B5C"
                                    BorderThickness="1">

                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            CornerRadius="16"
                                            Background="#1A2238"
                                            Padding="8">
                                        <Image Source="{Binding Car.ImagePath}"
                                               Height="120"
                                               Stretch="Uniform"/>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Spacing="7">
                                        <TextBlock Text="{Binding Car.Brand}"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Text="{Binding Car.Model}"
                                                   Foreground="#D1D5DB"
                                                   FontSize="15"/>

                                        <TextBlock Text="{Binding PickupLocation}"
                                                   Foreground="#A78BFA"
                                                   FontSize="14"/>

                                        <TextBlock Text="{Binding StartDate}"
                                                   Foreground="#9CA3AF"
                                                   FontSize="13"/>

                                        <TextBlock Text="{Binding EndDate}"
                                                   Foreground="#9CA3AF"
                                                   FontSize="13"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Spacing="10">

                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="#A78BFA"
                                                   FontSize="14"
                                                   HorizontalAlignment="Right"/>

                                        <TextBlock Text="{Binding TotalCost}"
                                                   Foreground="White"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>