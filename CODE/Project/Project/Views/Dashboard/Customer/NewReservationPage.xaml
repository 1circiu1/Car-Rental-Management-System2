<Page
    x:Class="Project.Views.Dashboard.Customer.NewReservationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Padding="32">
            <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#181825" Offset="0"/>
                <GradientStop Color="#221B2E" Offset="0.45"/>
                <GradientStop Color="#10243F" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Padding="32"
                CornerRadius="28"
                Background="#26263A"
                BorderBrush="#3B3B5C"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="980">

            <Grid ColumnSpacing="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Car card -->
                <Border Grid.Column="0"
                        CornerRadius="22"
                        Background="#1A2238"
                        Padding="22">

                    <StackPanel Spacing="16">
                        <Image x:Name="CarImage"
                               Height="210"
                               Stretch="Uniform"/>

                        <TextBlock x:Name="CarTitleText"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>

                        <TextBlock x:Name="CarPriceText"
                                   Foreground="#A78BFA"
                                   FontSize="18"/>

                        <TextBlock Text="Unavailable periods"
                                   Foreground="White"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,0"/>

                        <ListView x:Name="UnavailablePeriodsList"
                                  MaxHeight="180"
                                  SelectionMode="None"
                                  Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="#CFCFCF"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,4"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Reservation form -->
                <StackPanel Grid.Column="1" Spacing="16">

                    <TextBlock Text="New reservation"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <TextBlock Text="Choose your pick-up and return details."
                               FontSize="14"
                               Foreground="#CFCFCF"/>

                    <ComboBox x:Name="PickupLocationBox"
                              Header="Pick-up location"
                              PlaceholderText="Choose city"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Cluj-Napoca"/>
                        <ComboBoxItem Content="Satu Mare"/>
                        <ComboBoxItem Content="Oradea"/>
                        <ComboBoxItem Content="Timișoara"/>
                        <ComboBoxItem Content="Baia Mare"/>
                        <ComboBoxItem Content="București"/>
                    </ComboBox>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CalendarDatePicker x:Name="StartDatePicker"
                                            Grid.Column="0"
                                            Header="Pick-up date"
                                            DateChanged="ReservationDateTime_Changed"/>

                            <ComboBox x:Name="StartTimeBox"
                                  Grid.Column="1"
                                  Header="Pick-up time"
                                  SelectedIndex="0"
                                  SelectionChanged="ReservationDateTime_Changed">
                                <ComboBoxItem Content="08:00"/>
                                <ComboBoxItem Content="09:00"/>
                                <ComboBoxItem Content="10:00"/>
                                <ComboBoxItem Content="11:00"/>
                                <ComboBoxItem Content="12:00"/>
                                <ComboBoxItem Content="13:00"/>
                                <ComboBoxItem Content="14:00"/>
                                <ComboBoxItem Content="15:00"/>
                                <ComboBoxItem Content="16:00"/>
                                <ComboBoxItem Content="17:00"/>
                                <ComboBoxItem Content="18:00"/>
                                <ComboBoxItem Content="19:00"/>
                                <ComboBoxItem Content="20:00"/>
                            </ComboBox>
                        </Grid>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CalendarDatePicker x:Name="EndDatePicker"
                                            Grid.Column="0"
                                            Header="Return date"
                                            DateChanged="ReservationDateTime_Changed"/>

                            <ComboBox x:Name="EndTimeBox"
                                  Grid.Column="1"
                                  Header="Return time"
                                  SelectedIndex="10"
                                  SelectionChanged="ReservationDateTime_Changed">
                                <ComboBoxItem Content="08:00"/>
                                <ComboBoxItem Content="09:00"/>
                                <ComboBoxItem Content="10:00"/>
                                <ComboBoxItem Content="11:00"/>
                                <ComboBoxItem Content="12:00"/>
                                <ComboBoxItem Content="13:00"/>
                                <ComboBoxItem Content="14:00"/>
                                <ComboBoxItem Content="15:00"/>
                                <ComboBoxItem Content="16:00"/>
                                <ComboBoxItem Content="17:00"/>
                                <ComboBoxItem Content="18:00"/>
                                <ComboBoxItem Content="19:00"/>
                                <ComboBoxItem Content="20:00"/>
                            </ComboBox>
                        </Grid>

                    <Border Padding="18"
                            CornerRadius="18"
                            Background="#111827"
                            BorderBrush="#3B3B5C"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Reservation summary"
                                       Foreground="#A78BFA"
                                       FontSize="14"/>

                            <TextBlock x:Name="DurationText"
                                       Text="Duration: -"
                                       Foreground="#CFCFCF"
                                       FontSize="15"/>

                            <TextBlock x:Name="TotalPriceText"
                                       Text="€ 0.00"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="ErrorText"
                               Foreground="#F87171"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Confirm reservation"
                                Width="220"
                                Height="48"
                                Background="#8B5CF6"
                                Foreground="White"
                                Click="ConfirmReservation_Click"/>

                        <Button Content="Back"
                                Width="120"
                                Height="48"
                                Click="Back_Click"/>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </ScrollViewer>
</Page>