<Page
    x:Class="Project.Views.Dashboard.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="22">

            <!-- Welcome banner -->
            <Border Padding="32"
                    CornerRadius="24"
                    Background="#26263A"
                    BorderBrush="#3B3B5C"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <TextBlock x:Name="WelcomeText"
                                   Text="Welcome back!"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                        <TextBlock x:Name="WelcomeSubtitle"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#D1D5DB"
                                   TextWrapping="Wrap"
                                   MaxWidth="820"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="64"
                            Height="64"
                            CornerRadius="20"
                            Background="#8B5CF6">
                        <FontIcon Glyph="&#xE804;"
                                  FontSize="26"
                                  Foreground="White"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Stats cards -->
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="22"
                        CornerRadius="18"
                        Background="#26263A"
                        BorderBrush="#3B3B5C"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE787;" FontSize="24" Foreground="#93C5FD"/>
                        <TextBlock Text="Active reservations" Foreground="#D1D5DB"/>
                        <TextBlock x:Name="ReservationsCountText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Currently active rentals"
                                   FontSize="12"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="22"
                        CornerRadius="18"
                        Background="#26263A"
                        BorderBrush="#3B3B5C"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xEB51;" FontSize="24" Foreground="#A78BFA"/>
                        <TextBlock Text="Favorite cars" Foreground="#D1D5DB"/>
                        <TextBlock x:Name="FavoritesCountText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Saved for later"
                                   FontSize="12"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="22"
                        CornerRadius="18"
                        Background="#26263A"
                        BorderBrush="#3B3B5C"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE8BD;" FontSize="24" Foreground="#60A5FA"/>
                        <TextBlock Text="Support tickets" Foreground="#D1D5DB"/>
                        <TextBlock x:Name="SupportTicketsText"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Open requests"
                                   FontSize="12"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Two column layout -->
            <Grid ColumnSpacing="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <!-- Left column -->
                <StackPanel Grid.Column="0" Spacing="22">

                    <!-- Upcoming reservation -->
                    <Border Padding="24"
                            CornerRadius="22"
                            Background="#26263A"
                            BorderBrush="#3B3B5C"
                            BorderThickness="1">

                        <StackPanel Spacing="14">
                            <TextBlock Text="Upcoming reservation"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>

                            <Grid x:Name="UpcomingReservationPanel"
                                  ColumnSpacing="18">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        CornerRadius="16"
                                        Background="#1A2238"
                                        Padding="8">
                                    <Image x:Name="UpcomingCarImage"
                                           Height="115"
                                           Stretch="Uniform"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="6">
                                    <TextBlock x:Name="UpcomingCarNameText"
                                               Text="No upcoming reservations"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock x:Name="UpcomingLocationText"
                                               Text=""
                                               FontSize="14"
                                               Foreground="#A78BFA"/>

                                    <TextBlock x:Name="UpcomingDatesText"
                                               Text=""
                                               FontSize="13"
                                               Foreground="#D1D5DB"
                                               TextWrapping="Wrap"/>

                                    <TextBlock x:Name="UpcomingStatusText"
                                               Text=""
                                               FontSize="13"
                                               Foreground="#93C5FD"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Garage locations -->
                    <Border Padding="24"
                            CornerRadius="22"
                            BorderBrush="#60A5FA"
                            BorderThickness="1">

                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1E3A8A" Offset="0"/>
                                <GradientStop Color="#2563EB" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE707;"
                                          FontSize="22"
                                          Foreground="White"/>
                                <TextBlock Text="Garage locations"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>

                            <Grid ColumnSpacing="16" RowSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Cluj-Napoca" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Strada Memorandumului 18" Foreground="#DBEAFE"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1">
                                    <TextBlock Text="Satu Mare" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Bulevardul Lucian Blaga 42" Foreground="#DBEAFE"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="Oradea" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Strada Republicii 27" Foreground="#DBEAFE"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="Timișoara" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Piața Victoriei 9" Foreground="#DBEAFE"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Baia Mare" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Strada București 31" Foreground="#DBEAFE"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <TextBlock Text="București" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Calea Victoriei 145" Foreground="#DBEAFE"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right column -->
                <StackPanel Grid.Column="1" Spacing="22">

                    <!-- Return policy -->
                    <Border Padding="24"
                            CornerRadius="22"
                            BorderBrush="#C4B5FD"
                            BorderThickness="1">

                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4C1D95" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE916;"
                                          FontSize="22"
                                          Foreground="White"/>
                                <TextBlock Text="Return policy"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>

                            <TextBlock Text="Cars must be returned at least 15 minutes before the selected return time."
                                       Foreground="White"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Late returns may affect future bookings and vehicle availability."
                                       Foreground="#EDE9FE"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Rental tips -->
                    <Border Padding="24"
                            CornerRadius="22"
                            Background="#26263A"
                            BorderBrush="#3B3B5C"
                            BorderThickness="1">

                        <StackPanel Spacing="12">
                            <TextBlock Text="Rental tips"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>

                            <TextBlock Text="• Bring a valid ID"
                                       Foreground="#D1D5DB"
                                       FontSize="14"/>

                            <TextBlock Text="• Inspect the vehicle before pick-up"
                                       Foreground="#D1D5DB"
                                       FontSize="14"/>

                            <TextBlock Text="• Return fuel at the same level"
                                       Foreground="#D1D5DB"
                                       FontSize="14"/>

                            <TextBlock Text="• Contact support immediately for incidents"
                                       Foreground="#D1D5DB"
                                       FontSize="14"/>
                        </StackPanel>
                    </Border>

                    <!-- Recent activity -->
                    <Border Padding="24"
                            CornerRadius="22"
                            Background="#26263A"
                            BorderBrush="#3B3B5C"
                            BorderThickness="1">

                        <StackPanel Spacing="12">
                            <TextBlock Text="Recent activity"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>

                            <TextBlock x:Name="RecentActivityText"
                                       Text="No recent activity yet."
                                       Foreground="#D1D5DB"
                                       FontSize="14"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>