<Page
    x:Class="Project.Views.Dashboard.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="20">

            <!-- Welcome card -->
            <Border Padding="32"
                    CornerRadius="22"
                    Background="#252525"
                    BorderBrush="#333333"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <TextBlock x:Name="WelcomeText"
                                   Text="Welcome back!"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>

                        <TextBlock x:Name="WelcomeSubtitle"
                                   Text=""
                                   FontSize="14"
                                   Opacity="0.75"
                                   TextWrapping="Wrap"
                                   MaxWidth="780"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="58"
                            Height="58"
                            CornerRadius="18"
                            Background="#1A6EF5">
                        <FontIcon Glyph="&#xE804;"
                                  FontSize="24"
                                  Foreground="White"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Stats cards -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="20" CornerRadius="16"
                        Background="#252525" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE787;" FontSize="22" Foreground="#7AA2FF"/>
                        <TextBlock Text="Active reservations" Opacity="0.7"/>
                        <TextBlock x:Name="ReservationsCountText"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Currently active rentals" FontSize="12" Opacity="0.55"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" CornerRadius="16"
                        Background="#252525" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xEB51;" FontSize="22" Foreground="#7AA2FF"/>
                        <TextBlock Text="Favorite cars" Opacity="0.7"/>
                        <TextBlock x:Name="FavoritesCountText"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Saved for later" FontSize="12" Opacity="0.55"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="20" CornerRadius="16"
                        Background="#252525" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE8C7;" FontSize="22" Foreground="#7AA2FF"/>
                        <TextBlock Text="Total spent" Opacity="0.7"/>
                        <TextBlock x:Name="TotalSpentText"
                                   Text="$0"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Across all reservations" FontSize="12" Opacity="0.55"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Padding="20" CornerRadius="16"
                        Background="#252525" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE8BD;" FontSize="22" Foreground="#7AA2FF"/>
                        <TextBlock Text="Support tickets" Opacity="0.7"/>
                        <TextBlock x:Name="SupportTicketsText"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Open requests" FontSize="12" Opacity="0.55"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>