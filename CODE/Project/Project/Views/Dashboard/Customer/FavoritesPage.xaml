<Page
    x:Class="Project.Views.Dashboard.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="28">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#181825" Offset="0"/>
                <GradientStop Color="#221B2E" Offset="0.5"/>
                <GradientStop Color="#10243F" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer>
            <GridView x:Name="FavoritesGridView"
                  IsItemClickEnabled="True"
                  ItemClick="FavoritesGridView_ItemClick"
                  SelectionMode="None">

                <GridView.ItemTemplate>
                    <DataTemplate>

                        <Border Width="1000"
                            MinHeight="170"
                            Margin="0,0,0,18"
                            Padding="18"
                            CornerRadius="22"
                            Background="#26263A"
                            BorderBrush="#3B3B5C"
                            BorderThickness="1">

                            <Grid ColumnSpacing="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                    CornerRadius="16"
                                    Background="#1A2238"
                                    Padding="8">

                                    <Image Source="{Binding ImagePath}"
                                       Height="130"
                                       Stretch="Uniform"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="8">

                                    <TextBlock Text="{Binding Brand}"
                                           Foreground="White"
                                           FontSize="28"
                                           FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding Model}"
                                           Foreground="#D1D5DB"
                                           FontSize="16"/>

                                    <TextBlock Text="{Binding Year}"
                                           Foreground="#9CA3AF"
                                           FontSize="14"/>

                                    <TextBlock Text="{Binding PlateNumber}"
                                           Foreground="#9CA3AF"
                                           FontSize="14"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        Spacing="10">

                                    <TextBlock Text="Price / day"
                                           Foreground="#9CA3AF"
                                           FontSize="13"
                                           HorizontalAlignment="Right"/>

                                    <TextBlock Text="{Binding PricePerDay}"
                                           Foreground="#8B5CF6"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right"/>

                                    <Border Background="#312E81"
                                        CornerRadius="10"
                                        Padding="10,6">

                                        <TextBlock Text="View details"
                                               Foreground="White"
                                               FontSize="12"/>
                                    </Border>

                                </StackPanel>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>
    </Grid>
</Page>