<Page
    x:Class="Project.Views.Dashboard.CarsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>

        <StackPanel Spacing="20">

            <TextBlock Text="Available Cars"
                       FontSize="28"
                       FontWeight="SemiBold"/>

            <GridView x:Name="CarsGrid"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="CarsGrid_ItemClick">

                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>

                <GridView.ItemTemplate>
                    <DataTemplate>

                        <Border Width="280"
                                Padding="16"
                                CornerRadius="18"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">

                            <StackPanel Spacing="12">

                                <!-- IMAGE -->
                                <Border Height="150"
                                        CornerRadius="12"
                                        Background="#222">

                                    <Image Source="{Binding ImagePath}"
                                           Stretch="UniformToFill"/>
                                </Border>

                                <!-- BRAND -->
                                <TextBlock Text="{Binding Brand}"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>

                                <!-- MODEL -->
                                <TextBlock Text="{Binding Model}"
                                           FontSize="15"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <!-- YEAR -->
                                <TextBlock Text="{Binding Year}"/>

                                <!-- PLATE -->
                                <TextBlock Text="{Binding PlateNumber}"/>

                                <!-- PRICE -->
                                <StackPanel Orientation="Horizontal"
                                            Spacing="4">

                                    <TextBlock Text="€"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding PricePerDay}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="/ day"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                </StackPanel>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </GridView.ItemTemplate>

            </GridView>

        </StackPanel>

    </ScrollViewer>

</Page>