<Page
    x:Class="Project.Views.Dashboard.CarDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="24"
                Background="#222222"
                Padding="24">
            <Image x:Name="CarImage"
                   Stretch="Uniform"/>
        </Border>

        <Border Grid.Column="1"
                Margin="28,0,0,0"
                Padding="32"
                CornerRadius="24"
                Background="#2B2B2B">

            <StackPanel Spacing="18">

                <Button Content="← Back"
                        Width="100"
                        Click="Back_Click"/>

                <TextBlock x:Name="CarTitle"
                           FontSize="36"
                           FontWeight="SemiBold"
                           Foreground="White"/>

                <TextBlock x:Name="CarModel"
                           FontSize="18"
                           Foreground="#CFCFCF"/>

                <StackPanel Spacing="10">
                    <TextBlock x:Name="CarYear"
                               FontSize="16"
                               Foreground="White"/>

                    <TextBlock x:Name="CarPlate"
                               FontSize="16"
                               Foreground="White"/>

                    <TextBlock x:Name="CarStatus"
                               FontSize="16"
                               Foreground="White"/>
                </StackPanel>

                <Border Padding="18"
                        CornerRadius="16"
                        Background="#1F1F1F">
                    <StackPanel>
                        <TextBlock Text="Price per day"
                                   Foreground="#CFCFCF"
                                   FontSize="14"/>

                        <TextBlock x:Name="CarPrice"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal"
                            Spacing="12">
                    <Button Content="Reserve"
                            Width="180"
                            Height="48"
                            Background="#A78BFA"
                            Foreground="Black"/>

                    <Button x:Name="BtnFavorite"
                            Content="♡ Favorite"
                            Width="160"
                            Height="48"
                            Click="Favorite_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>